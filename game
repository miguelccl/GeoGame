        const complementares = [
            "Mecânica Quântica", "Espaço-Tempo", "Teoria de Cordas", "Gravidade Quântica em Loops", "Flutuação de Vácuo", "Entropia de Bekenstein", "Princípio Holográfico", "Efeito Unruh", "Métrica de Vaidya", "Solução de Oppenheimer-Volkoff", "Flutuações Quânticas Cósmicas", "Efeito Lense-Thirring", "Precessão de Geodésica", "Desvio para o Vermelho Gravitacional", "Dilatação do Tempo de Einstein", "Astrofísica de Altas Energias", "Supernovas do Tipo II", "Hipernovas Extremas", "Sistemas Binários de Raios X", "Microquasares da Via Láctea"
