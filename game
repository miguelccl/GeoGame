        document.getElementById('btnRestartDefeat').addEventListener('click', resetToMenu);

        function shuffle(array) {
            for (let i = array.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [array[i], array[j]] = [array[j], array[i]];
            }
            return array;
        }

        function startMission() {
            playSynthSound('start');
            // Sorteia 15 dinamicamente da matriz de 100
            let pool = shuffle([...QUESTIONS]);
            selectedQuestions = pool.slice(0, totalGameQuestions);
            
            currentQuestionIndex = 0; score = 0; errors = 0;
            gameEarth.className = "relative z-10 flex flex-col items-center transition-all duration-700";
            gameEarth.style.transform = "translateX(0px)";
            
            txtScore.textContent = "0000";
            updateMetrics();
            screenStart.classList.add('hidden'); screenVictory.classList.add('hidden'); screenDefeat.classList.add('hidden');
            screenGame.classList.remove('hidden');
            loadQuestion();
        }

        function loadQuestion() {
            clearInterval(timerInterval);
            timeLeft = 25;
            txtTimer.textContent = `${timeLeft}s`;
            txtTimer.className = "text-base font-bold text-yellow-400 font-orbitron";

            timerInterval = setInterval(() => {
                timeLeft--;
                txtTimer.textContent = `${timeLeft}s`;
                if (timeLeft <= 5) txtTimer.className = "text-base font-bold text-red-500 font-orbitron animate-pulse";
                if (timeLeft <= 0) { clearInterval(timerInterval); handleTimeout(); }
            }, 1000);

            const qData = selectedQuestions[currentQuestionIndex];
            lblQuestion.textContent = qData.q;
            lblCuriosity.textContent = qData.c;

            answersContainer.innerHTML = '';
            qData.o.forEach((opt, index) => {
                const btn = document.createElement('button');
                btn.className = "w-full text-left p-3 rounded-xl bg-slate-950/70 hover:bg-slate-900 border border-cyan-950 hover:border-cyan-400 font-mono text-xs md:text-sm transition flex items-start space-x-3";
                const letter = String.fromCharCode(65 + index);
                btn.innerHTML = `
                    <span class="inline-flex items-center justify-center w-5 h-5 rounded bg-cyan-950 border border-cyan-500/30 text-cyan-400 font-bold text-2xs shrink-0">${letter}</span>
                    <span class="text-gray-200">${opt}</span>
                `;
                btn.addEventListener('click', () => selectAnswer(index, btn));
                answersContainer.appendChild(btn);
            });

            txtQuestionCounter.textContent = `${padZero(currentQuestionIndex + 1)} / ${padZero(totalGameQuestions)}`;
        }

        function selectAnswer(selectedIndex, buttonElement) {
            clearInterval(timerInterval);
            const qData = selectedQuestions[currentQuestionIndex];
            const buttons = answersContainer.querySelectorAll('button');
            buttons.forEach(b => b.disabled = true);

            if (selectedIndex === qData.a) {
                playSynthSound('correct');
                score += 100 + (timeLeft * 2);
                txtScore.textContent = padZero(score);
                buttonElement.className = "w-full text-left p-3 rounded-xl bg-green-950/60 border border-green-400 font-mono text-xs md:text-sm flex items-start space-x-3 neon-border-blue";
            } else {
                playSynthSound('incorrect');
                errors++;
                document.body.classList.add('shake-effect'); setTimeout(() => document.body.classList.remove('shake-effect'), 400);
                buttonElement.className = "w-full text-left p-3 rounded-xl bg-red-950/60 border border-red-500 font-mono text-xs md:text-sm flex items-start space-x-3 neon-border-pink";
                buttons[qData.a].classList.add('border-green-500', 'bg-green-950/20');
            }

            updateMetrics();

            setTimeout(() => {
                if (errors >= maxErrors) { endGame(false); } 
                else {
                    currentQuestionIndex++;
                    if (currentQuestionIndex < totalGameQuestions) { loadQuestion(); } 
                    else { endGame(true); }
                }
            }, 3500);
        }

        function handleTimeout() {
            playSynthSound('incorrect');
            errors++;
            document.body.classList.add('shake-effect'); setTimeout(() => document.body.classList.remove('shake-effect'), 400);
            updateMetrics();

            const buttons = answersContainer.querySelectorAll('button');
            buttons.forEach(b => b.disabled = true);
            const qData = selectedQuestions[currentQuestionIndex];
            buttons[qData.a].classList.add('border-green-500', 'bg-green-950/20');

            lblQuestion.innerHTML = `<span class="text-red-500 font-bold font-orbitron">JANELA DE TEMPO EXCEDIDA!</span> Escudos danificados por instabilidade quântica.`;

            setTimeout(() => {
                if (errors >= maxErrors) { endGame(false); } 
                else {
                    currentQuestionIndex++;
                    if (currentQuestionIndex < totalGameQuestions) { loadQuestion(); } 
                    else { endGame(true); }
                }
            }, 3500);
        }

        function updateMetrics() {
            const pctShield = Math.max(0, 100 - (errors * 33.34));
            txtShield.textContent = `${Math.ceil(pctShield)}%`;
            barShield.style.width = `${pctShield}%`;

            const distance = Math.max(0, 120000 - (errors * 40000));
            txtDistance.textContent = `${distance.toLocaleString('pt-BR')} KM`;
            barDistance.style.width = `${(distance / 120000) * 100}%`;

            const displacement = errors * 45; 
            gameEarth.style.transform = `translateX(${displacement}px)`;
        }

        function endGame(isVictory) {
            clearInterval(timerInterval);
            screenGame.classList.add('hidden');
            if (isVictory) {
                screenVictory.classList.remove('hidden');
                document.getElementById('finalScoreVictory').textContent = padZero(score);
            } else {
                screenGame.classList.remove('hidden');
                gameEarth.className = "relative z-10 succumb-earth";
                setTimeout(() => {
                    screenGame.classList.add('hidden');
                    screenDefeat.classList.remove('hidden');
                }, 2000);
            }
        }

        function resetToMenu() {
            screenVictory.classList.add('hidden'); screenDefeat.classList.add('hidden'); screenStart.classList.remove('hidden');
        }

        function padZero(num) { return num < 10 ? `0${num}` : num; }
    </script>
</body>
</html>
